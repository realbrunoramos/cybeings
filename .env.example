# --- Database (Supabase / PostgreSQL) ---
# Transaction-mode pooler (port 6543) for the app runtime; session-mode (5432) for Prisma CLI.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres"

# --- Cache & Pub/Sub (Upstash / Redis) ---
UPSTASH_REDIS_REST_URL="https://host.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# --- Unstructured data (MongoDB Atlas) ---
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/cybeings"

# --- Blockchain (Alchemy / Ethereum) ---
